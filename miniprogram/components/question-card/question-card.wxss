.question-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.question-header {
  margin-bottom: 24rpx;
}

.question-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
}

.question-total {
  font-size: 28rpx;
  color: #999999;
  margin-left: 8rpx;
}

.question-content {
  margin-bottom: 32rpx;
}

.question-text {
  font-size: 32rpx;
  line-height: 1.6;
  color: #333333;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.option-item.selected {
  background: rgba(102, 126, 234, 0.1);
  border-color: #667eea;
}

.option-item.correct {
  background: rgba(82, 196, 26, 0.1);
  border-color: #52c41a;
}

.option-item.wrong {
  background: rgba(255, 77, 79, 0.1);
  border-color: #ff4d4f;
}

.option-label {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.option-item.selected .option-label {
  background: #667eea;
  color: #ffffff;
}

.option-item.correct .option-label {
  background: #52c41a;
  color: #ffffff;
}

.option-item.wrong .option-label {
  background: #ff4d4f;
  color: #ffffff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.option-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #52c41a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-left: 16rpx;
}

.option-icon.wrong-icon {
  background: #ff4d4f;
}
