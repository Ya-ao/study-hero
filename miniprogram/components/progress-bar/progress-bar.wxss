.progress-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #ffffff;
}

.progress-track {
  flex: 1;
  height: 12rpx;
  background: #e8e8e8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  margin-left: 16rpx;
  font-size: 28rpx;
}

.progress-text .current {
  color: #667eea;
  font-weight: 600;
}

.progress-text .total {
  color: #999999;
}
