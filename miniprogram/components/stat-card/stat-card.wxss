.stat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #667eea;
}

.stat-unit {
  font-size: 24rpx;
  color: #999999;
  margin-left: 4rpx;
}

.stat-title {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}
