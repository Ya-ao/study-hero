.container {
  padding: 32rpx;
  padding-bottom: 200rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.result-header {
  text-align: center;
  padding: 48rpx 0;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 36rpx;
  color: #333333;
  margin-bottom: 24rpx;
}

.score-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 16rpx;
}

.score-value {
  font-size: 96rpx;
  font-weight: 600;
  color: #667eea;
}

.score-unit {
  font-size: 32rpx;
  color: #999999;
  margin-left: 8rpx;
}

.accuracy {
  font-size: 28rpx;
  color: #666666;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e8e8e8;
}

.wrong-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.wrong-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.wrong-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.wrong-header {
  margin-bottom: 16rpx;
}

.wrong-number {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

.wrong-question {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.wrong-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.wrong-option {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
}

.wrong-option.user-answer {
  background: rgba(255, 77, 79, 0.1);
  border-color: #ff4d4f;
}

.wrong-option.correct-answer {
  background: rgba(82, 196, 26, 0.1);
  border-color: #52c41a;
}

.option-label {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666666;
  margin-right: 12rpx;
}

.wrong-option.user-answer .option-label {
  background: #ff4d4f;
  color: #ffffff;
}

.wrong-option.correct-answer .option-label {
  background: #52c41a;
  color: #ffffff;
}

.option-text {
  font-size: 26rpx;
  color: #333333;
}

.answer-hint {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999999;
  padding-top: 16rpx;
  border-top: 2rpx solid #f5f7fa;
}

.wrong-explanation {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
}

.explanation-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 8rpx;
}

.explanation-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.action-buttons {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.retry-btn {
  flex: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 44rpx;
  padding: 20rpx 0;
  border: none;
}

.retry-btn::after {
  border: none;
}

.share-btn {
  flex: 1;
  background: #52c41a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 44rpx;
  padding: 20rpx 0;
  border: none;
}

.share-btn::after {
  border: none;
}

.home-btn {
  flex: 1;
  background: #ffffff;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 44rpx;
  padding: 18rpx 0;
  border: 2rpx solid #667eea;
}

.home-btn::after {
  border: none;
}

.achievement-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
  width: 80%;
  max-width: 560rpx;
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.modal-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 32rpx;
}

.modal-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  padding: 24rpx 0;
}
