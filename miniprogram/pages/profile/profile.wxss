.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.user-section {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid #667eea;
}

.user-name {
  margin-top: 16rpx;
}

.nickname-input {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
}

.stats-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.achievement-section {
  margin-bottom: 32rpx;
}

.achievement-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  min-width: 140rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.achievement-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.achievement-name {
  font-size: 24rpx;
  color: #666666;
}

.history-section {
  margin-bottom: 32rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.history-info {
  display: flex;
  flex-direction: column;
}

.history-topic {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.history-time {
  font-size: 24rpx;
  color: #999999;
}

.history-score {
  display: flex;
  align-items: baseline;
}

.score-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #667eea;
}

.score-unit {
  font-size: 24rpx;
  color: #999999;
  margin-left: 4rpx;
}

.empty-history {
  text-align: center;
  padding: 48rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
