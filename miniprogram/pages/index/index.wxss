.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 32rpx 0;
}

.logo {
  font-size: 44rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 8rpx;
}

.slogan {
  font-size: 26rpx;
  color: #999999;
}

.start-section {
  margin-bottom: 32rpx;
}

.start-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.start-content {
  display: flex;
  flex-direction: column;
}

.start-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.start-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.start-btn {
  background: #ffffff;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  border: none;
}

.start-btn::after {
  border: none;
}

.stats-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.recent-section {
  margin-bottom: 32rpx;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.recent-info {
  display: flex;
  flex-direction: column;
}

.recent-topic {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.recent-time {
  font-size: 24rpx;
  color: #999999;
}

.recent-score {
  display: flex;
  align-items: baseline;
}

.score-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #667eea;
}

.score-unit {
  font-size: 24rpx;
  color: #999999;
  margin-left: 4rpx;
}

.empty-section {
  text-align: center;
  padding: 64rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
