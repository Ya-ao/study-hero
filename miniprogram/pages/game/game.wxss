.container {
  min-height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
}

.game-content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 200rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  padding: 24rpx 0;
  border: none;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn[disabled] {
  opacity: 0.5;
}

.result-info {
  text-align: center;
  margin-bottom: 24rpx;
}

.result-text {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.result-text.correct {
  color: #52c41a;
}

.result-text.wrong {
  color: #ff4d4f;
}

.correct-answer {
  font-size: 28rpx;
  color: #666666;
}

.explanation {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  text-align: left;
}

.explanation-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 12rpx;
}

.explanation-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.next-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  padding: 24rpx 0;
  border: none;
}

.next-btn::after {
  border: none;
}
